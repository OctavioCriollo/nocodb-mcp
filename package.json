  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OctavioCriollo/nocodb-mcp.git"
  },
  "homepage": "https://github.com/OctavioCriollo/nocodb-mcp",
  "bugs": {
    "url": "https://github.com/OctavioCriollo/nocodb-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
