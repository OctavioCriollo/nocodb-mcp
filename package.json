  "types": "dist/index.d.ts",
  "bin": {
    "nocodb-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "nocodb",
    "database",
    "airtable",
    "model-context-protocol",
